{
	"cSpell.words": [
		"cafile",
		"certfile",
		"mosquitto",
		"mqtt",
		"mqttc",
		"nodelay",
		"noout",
		"paho",
		"pems",
		"reasoncodes",
		"reqs",
		"sslip",
		"SUBACK",
		"trustme",
		"unacked",
	],
	"python.terminal.useEnvFile": false,
	"chat.tools.terminal.autoApprove": {
		"/.*mqtt-learn1 && timeout 8s poe sub1$/": {
			"approve": true,
			"matchCommandLine": true,
		},
		"/.*mqtt-learn1 && poe .+$/": {
			"approve": true,
			"matchCommandLine": true,
		},
		"/.*mqtt-learn1 && docker compose -p mqtt-learn1 -f docker-compose\\.yml logs mqtt --tail 200$/": {
			"approve": true,
			"matchCommandLine": true,
		},
		"/.*mqtt-learn1 && timeout 5s poe sub3 2>&1 \\|\\| true$/": {
			"approve": true,
			"matchCommandLine": true,
		},
		"docker compose": true,
	},
}
